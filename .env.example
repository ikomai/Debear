# ─────────── Telegram ───────────
# Get a token from @BotFather in Telegram and paste it here.
BOT_TOKEN=123456:PASTE_YOUR_TOKEN_HERE

# Comma-separated Telegram user IDs that get admin access.
# Find your id via @userinfobot.
ADMIN_IDS=

# ─────────── Database ───────────
# DB_ENGINE = sqlite  -> runs locally, zero setup (default, good for development)
# DB_ENGINE = mysql   -> uses the MySQL settings below (production)
DB_ENGINE=sqlite

# SQLite file (used only when DB_ENGINE=sqlite)
SQLITE_PATH=bot.db

# MySQL settings (used only when DB_ENGINE=mysql)
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=your-mysql-database

# ─────────── Files ───────────
# Where uploaded documents and generated PDFs are stored locally.
STORAGE_DIR=storage
